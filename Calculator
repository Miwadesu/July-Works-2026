#include <stdio.h>

int code;
float num1, num2, addi, subbi, multi, divi;
float add()
{
    printf("Please input first number: ");
    scanf("%f", &num1);
    printf("Please input second number: ");
    scanf("%f", &num2);
    addi = num1 + num2;
    printf("The answer is %.2f", addi);
}
float sub()
{
    printf("Please input first number: ");
    scanf("%f", &num1);
    printf("Please input second number: ");
    scanf("%f", &num2);
    subbi = num1 - num2;
    printf("The answer is %.2f", subbi);
}
float mul()
{
    printf("Please input first number: ");
    scanf("%f", &num1);
    printf("Please input second number: ");
    scanf("%f", &num2);
    multi = num1 * num2;
    printf("The answer is %.2f", multi);
}
float div()
{
    printf("Please input first number: ");
    scanf("%f", &num1);
    printf("Please input second number: ");
    scanf("%f", &num2);
    divi = num1 / num2;
    printf("The answer is %.2f", divi);
}

int main()
{
    printf("=====Calculator=====\n");
    printf("1. Addition\t        2. Subtraction\n3. Multiplication\t4. Division\n");
    printf("Please choose what operator you will be using: \n");
    scanf("%d", &code);
    switch(code){
    case 1: 
    add();
    break;
    case 2:
    sub();
    break;
    case 3:
    mul();
    break;
    case 4:
    div();
    default:
    printf("Wrong number. Please choose again.");
    }
    return 0;
}
